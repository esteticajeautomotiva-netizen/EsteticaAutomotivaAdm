<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>J&E Estética Automotiva — Painel ADM</title>
<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#D4AF37">
<link rel="apple-touch-icon" href="icons/icon-192.png">
<link rel="stylesheet" href="css/vars.css">
<link rel="stylesheet" href="css/admin.css">
</head>
<body>
<div id="toast-container"></div>
<button class="menu-toggle" id="menu-toggle">☰</button>
<div class="sidebar-overlay" id="sidebar-overlay"></div>

<!-- ============================================================ -->
<!--  SIDEBAR                                                     -->
<!-- ============================================================ -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-logo">
    <div class="logo-icon" style="border-radius:50%;overflow:hidden;padding:0;background:none"><img src="https://res.cloudinary.com/dmqtygmro/image/upload/v1778716782/WhatsApp_Image_2026-05-07_at_22.51.51_fac8lq.jpg" alt="J&E" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:50%"></div>
    <div class="logo-text">J&amp;E Estética<small>Painel ADM</small></div>
  </div>

  <nav class="sidebar-nav">
    <a class="sidebar-item active" data-page="dashboard">
      <span class="icon">📊</span> Dashboard
    </a>
    <a class="sidebar-item" data-page="agendamentos">
      <span class="icon">📅</span> Agendamentos
    </a>
    <hr class="sidebar-divider">
    <a class="sidebar-item" data-page="servicos">
      <span class="icon">🚗</span> Serviços
    </a>
    <a class="sidebar-item" data-page="especialistas">
      <span class="icon">👨‍🔧</span> Especialistas
    </a>
    <a class="sidebar-item" data-page="galeria">
      <span class="icon">📸</span> Galeria
    </a>
    <hr class="sidebar-divider">
    <a class="sidebar-item" data-page="configuracoes">
      <span class="icon">⚙️</span> Configurações
    </a>
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-user">
      <div style="width:36px;height:36px;border-radius:50%;background:var(--cyan-dim);border:1px solid var(--cyan);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0">👤</div>
      <div class="info">
        <div class="name" id="admin-name">Admin</div>
        <div class="role">Administrador</div>
      </div>
    </div>
    <button class="sidebar-item" id="btn-logout" style="color:var(--danger);margin-top:8px">
      <span class="icon">🚪</span> Sair
    </button>
  </div>
</aside>

<!-- ============================================================ -->
<!--  MAIN CONTENT                                                -->
<!-- ============================================================ -->
<main class="main-content">

  <!-- ---- DASHBOARD ---- -->
  <div id="page-dashboard" class="page active">
    <div class="page-header">
      <div>
        <div class="page-title">Dashboard</div>
        <div class="page-subtitle" id="today-label">Carregando...</div>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card cyan">
        <div class="stat-icon">📅</div>
        <div class="stat-value" id="stat-hoje">—</div>
        <div class="stat-label">Agendamentos Hoje</div>
      </div>
      <div class="stat-card gold">
        <div class="stat-icon">⏳</div>
        <div class="stat-value" id="stat-pendentes">—</div>
        <div class="stat-label">Pendentes</div>
      </div>
      <div class="stat-card green">
        <div class="stat-icon">✅</div>
        <div class="stat-value" id="stat-confirmados">—</div>
        <div class="stat-label">Confirmados</div>
      </div>
      <div class="stat-card red">
        <div class="stat-icon">💰</div>
        <div class="stat-value" id="stat-receita">—</div>
        <div class="stat-label">Receita Total</div>
      </div>
    </div>

    <!-- Receita por Especialista -->
    <div class="card" style="margin-bottom:24px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:12px">
        <h3 style="font-family:var(--font-display);font-size:18px;font-weight:800;text-transform:uppercase">
          💰 Receita por Especialista
        </h3>
        <div style="display:flex;gap:8px;flex-wrap:wrap" id="receita-period-btns">
          <button class="filter-btn active" data-period="mes" onclick="changePeriod(this,'mes')">Este Mês</button>
          <button class="filter-btn" data-period="semana" onclick="changePeriod(this,'semana')">Esta Semana</button>
          <button class="filter-btn" data-period="total" onclick="changePeriod(this,'total')">Total Geral</button>
        </div>
      </div>
      <div id="receita-especialistas">
        <div style="text-align:center;padding:24px;color:var(--text-2)"><span class="spinner"></span></div>
      </div>
    </div>

    <!-- Agendamentos de Hoje -->
    <div class="card" style="margin-bottom:24px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
        <h3 style="font-family:var(--font-display);font-size:18px;font-weight:800;text-transform:uppercase">
          📋 Agendamentos de Hoje
        </h3>
        <button class="btn btn-outline btn-sm" onclick="showPage('agendamentos')">Ver todos</button>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Hora</th>
              <th>Cliente</th>
              <th>Serviço</th>
              <th>Especialista</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody id="today-appointments">
            <tr><td colspan="5" style="text-align:center;padding:20px;color:var(--text-2)">Carregando...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ---- AGENDAMENTOS ---- -->
  <div id="page-agendamentos" class="page">
    <div class="page-header">
      <div>
        <div class="page-title">Agendamentos</div>
        <div class="page-subtitle">Gerencie todos os agendamentos</div>
      </div>
    </div>

    <div class="appointments-filters">
      <button class="filter-btn active" data-filter="todos">Todos</button>
      <button class="filter-btn" data-filter="pendente">Pendentes</button>
      <button class="filter-btn" data-filter="confirmado">Confirmados</button>
      <button class="filter-btn" data-filter="concluido">Concluídos</button>
      <button class="filter-btn" data-filter="cancelado">Cancelados</button>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Data</th>
            <th>Hora</th>
            <th>Cliente</th>
            <th>Telefone</th>
            <th>Serviço</th>
            <th>Especialista</th>
            <th>Status</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody id="appointments-tbody">
          <tr><td colspan="8" style="text-align:center;padding:20px;color:var(--text-2)">Carregando...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ---- SERVIÇOS ---- -->
  <div id="page-servicos" class="page">
    <div class="page-header">
      <div>
        <div class="page-title">Serviços</div>
        <div class="page-subtitle">Cadastre e gerencie os serviços disponíveis</div>
      </div>
      <button class="btn btn-primary" onclick="openServiceModal()">
        + Novo Serviço
      </button>
    </div>
    <div class="admin-list" id="services-list">
      <p style="color:var(--text-2)">Carregando...</p>
    </div>
  </div>

  <!-- ---- ESPECIALISTAS ---- -->
  <div id="page-especialistas" class="page">
    <div class="page-header">
      <div>
        <div class="page-title">Especialistas</div>
        <div class="page-subtitle">Cadastre e gerencie a equipe</div>
      </div>
      <button class="btn btn-primary" onclick="openSpecialistModal()">
        + Novo Especialista
      </button>
    </div>
    <div class="admin-list" id="specialists-list">
      <p style="color:var(--text-2)">Carregando...</p>
    </div>
  </div>

  <!-- ---- GALERIA ---- -->
  <div id="page-galeria" class="page">
    <div class="page-header">
      <div>
        <div class="page-title">Galeria da Semana</div>
        <div class="page-subtitle">Até 10 fotos dos trabalhos realizados</div>
      </div>
    </div>
    <div class="card">
      <div class="gallery-count" id="gallery-count">0/10 fotos</div>
      <div class="gallery-admin-grid" id="gallery-admin-grid">
        <p style="color:var(--text-2)">Carregando galeria...</p>
      </div>
      <p style="color:var(--text-2);font-size:12px;margin-top:12px">
        💡 Clique no botão "+" para adicionar fotos. Você pode tirar uma foto diretamente ou escolher da galeria do dispositivo.
      </p>
    </div>
  </div>

  <!-- ---- CONFIGURAÇÕES ---- -->
  <div id="page-configuracoes" class="page">
    <div class="page-header">
      <div>
        <div class="page-title">Configurações</div>
        <div class="page-subtitle">Horários de funcionamento e disponibilidade</div>
      </div>
    </div>

    <div class="grid-2" style="gap:24px;align-items:start">

      <!-- Horários -->
      <div class="card">
        <h3 style="font-family:var(--font-display);font-size:18px;font-weight:800;text-transform:uppercase;margin-bottom:20px">
          🕐 Horário de Funcionamento
        </h3>
        <div class="form-stack" style="display:flex;flex-direction:column;gap:14px">
          <div class="grid-2" style="gap:14px">
            <div class="input-group">
              <label>Abertura</label>
              <input type="time" id="hora-inicio" class="input" value="08:00">
            </div>
            <div class="input-group">
              <label>Fechamento</label>
              <input type="time" id="hora-fim" class="input" value="18:00">
            </div>
          </div>

          <div class="input-group">
            <label>Dias de Atendimento</label>
            <div class="horarios-grid" style="margin-top:8px">
              <div class="dia-toggle" data-dia="0">
                <div class="dia-nome">Dom</div><div class="dia-check"></div>
              </div>
              <div class="dia-toggle checked" data-dia="1">
                <div class="dia-nome">Seg</div><div class="dia-check">✓</div>
              </div>
              <div class="dia-toggle checked" data-dia="2">
                <div class="dia-nome">Ter</div><div class="dia-check">✓</div>
              </div>
              <div class="dia-toggle checked" data-dia="3">
                <div class="dia-nome">Qua</div><div class="dia-check">✓</div>
              </div>
              <div class="dia-toggle checked" data-dia="4">
                <div class="dia-nome">Qui</div><div class="dia-check">✓</div>
              </div>
              <div class="dia-toggle checked" data-dia="5">
                <div class="dia-nome">Sex</div><div class="dia-check">✓</div>
              </div>
              <div class="dia-toggle checked" data-dia="6">
                <div class="dia-nome">Sáb</div><div class="dia-check">✓</div>
              </div>
            </div>
          </div>

          <button class="btn btn-primary" id="btn-save-settings" onclick="saveSettings()">
            💾 Salvar Configurações
          </button>
        </div>
      </div>

      <!-- Info sobre duração por serviço -->
      <div class="card">
        <h3 style="font-family:var(--font-display);font-size:18px;font-weight:800;text-transform:uppercase;margin-bottom:16px">
          ⏱ Duração por Serviço
        </h3>
        <p style="color:var(--text-2);font-size:13px;line-height:1.6">
          A duração de cada serviço define os intervalos de horários disponíveis para os clientes.<br><br>
          Configure a duração ao cadastrar ou editar um serviço na aba <strong>Serviços</strong>.
        </p>
        <hr class="divider">
        <div style="font-size:13px;color:var(--text-2)">
          <p>📌 <strong>Exemplo:</strong></p>
          <p>Serviço de 30 min com abertura às 08:00 gera slots: 08:00, 08:30, 09:00...</p>
          <p>Serviço de 60 min gera: 08:00, 09:00, 10:00...</p>
        </div>
      </div>
    </div>
  </div>

</main>

<!-- ============================================================ -->
<!--  MODAL: SERVIÇO                                             -->
<!-- ============================================================ -->
<div id="service-modal" class="modal-backdrop hidden" onclick="if(event.target===this)closeServiceModal()">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title" id="service-modal-title">Novo Serviço</div>
      <button class="modal-close" onclick="closeServiceModal()">✕</button>
    </div>

    <input type="hidden" id="service-id">
    <div style="display:flex;flex-direction:column;gap:14px">

      <!-- Foto do serviço -->
      <div class="input-group">
        <label>Foto do Serviço</label>
        <div class="photo-upload-area">
          <input type="file" id="service-foto-input" accept="image/*" capture="environment">
          <div class="icon">📷</div>
          <p>Toque para escolher foto ou tirar uma</p>
        </div>
        <img id="service-foto-preview" style="width:100%;height:140px;object-fit:cover;border-radius:var(--radius);margin-top:8px;display:none" alt="Preview">
      </div>

      <div class="input-group">
        <label>Nome do Serviço *</label>
        <input type="text" id="service-nome" class="input" placeholder="Ex: Lavagem Completa">
      </div>

      <div class="input-group">
        <label>Descrição</label>
        <textarea id="service-desc" class="input" placeholder="Descreva o serviço..."></textarea>
      </div>

      <div class="grid-2" style="gap:14px">
        <div class="input-group">
          <label>Preço (R$)</label>
          <input type="number" id="service-preco" class="input" placeholder="0.00" min="0" step="0.01">
        </div>
        <div class="input-group">
          <label>Duração (minutos)</label>
          <select id="service-duracao" class="input">
            <option value="15">15 min</option>
            <option value="30" selected>30 min</option>
            <option value="45">45 min</option>
            <option value="60">1 hora</option>
            <option value="90">1h 30min</option>
            <option value="120">2 horas</option>
            <option value="180">3 horas</option>
            <option value="240">4 horas</option>
          </select>
        </div>
      </div>

      <label style="display:flex;align-items:center;gap:10px;cursor:pointer;font-size:14px">
        <input type="checkbox" id="service-ativo" checked
               style="width:16px;height:16px;accent-color:var(--cyan)">
        Serviço ativo (visível para clientes)
      </label>

      <div style="display:flex;gap:10px;margin-top:8px">
        <button class="btn btn-outline" onclick="closeServiceModal()">Cancelar</button>
        <button class="btn btn-primary" id="btn-save-service" onclick="saveService()" style="flex:1">Salvar</button>
      </div>
    </div>
  </div>
</div>

<!-- ============================================================ -->
<!--  MODAL: ESPECIALISTA                                        -->
<!-- ============================================================ -->
<div id="specialist-modal" class="modal-backdrop hidden" onclick="if(event.target===this)closeSpecialistModal()">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title" id="spec-modal-title">Novo Especialista</div>
      <button class="modal-close" onclick="closeSpecialistModal()">✕</button>
    </div>

    <input type="hidden" id="spec-id">
    <div style="display:flex;flex-direction:column;gap:14px">

      <!-- Foto do especialista -->
      <div style="display:flex;align-items:center;gap:16px">
        <div style="position:relative;flex-shrink:0">
          <img id="spec-foto-preview" class="avatar avatar-xl" alt="Foto"
               src="https://ui-avatars.com/api/?name=N&background=1A1F2E&color=00D4FF&bold=true&size=110"
               style="display:block">
          <label style="position:absolute;bottom:0;right:0;background:var(--cyan);color:#000;width:28px;height:28px;
                        border-radius:50%;display:flex;align-items:center;justify-content:center;
                        font-size:14px;cursor:pointer">
            📷
            <input type="file" id="spec-foto-input" accept="image/*" capture="user" style="display:none">
          </label>
        </div>
        <div style="flex:1">
          <p style="font-size:12px;color:var(--text-2)">Foto de perfil do especialista.<br>Ficará visível para os clientes.</p>
        </div>
      </div>

      <div class="input-group">
        <label>Nome *</label>
        <input type="text" id="spec-nome" class="input" placeholder="Nome completo">
      </div>

      <div class="input-group">
        <label>Telefone / WhatsApp</label>
        <input type="tel" id="spec-fone" class="input" placeholder="(11) 9xxxx-xxxx">
      </div>

      <div class="input-group">
        <label>Especialidades (separadas por vírgula)</label>
        <input type="text" id="spec-esp" class="input" placeholder="Ex: Lavagem, Polimento, Cristalização">
      </div>

      <div id="spec-senha-group" class="input-group" style="display:flex;flex-direction:column;gap:14px">
        <hr class="divider">
        <p style="font-size:12px;color:var(--text-2)">🔐 Dados de acesso ao app do especialista:</p>
        <div class="input-group">
          <label>E-mail de acesso *</label>
          <input type="email" id="spec-email" class="input" placeholder="email@exemplo.com">
        </div>
        <div class="input-group">
          <label>Senha inicial *</label>
          <input type="password" id="spec-senha" class="input" placeholder="Mínimo 6 caracteres">
        </div>
      </div>

      <label style="display:flex;align-items:center;gap:10px;cursor:pointer;font-size:14px">
        <input type="checkbox" id="spec-ativo" checked
               style="width:16px;height:16px;accent-color:var(--cyan)">
        Especialista ativo
      </label>

      <div style="display:flex;gap:10px;margin-top:8px">
        <button class="btn btn-outline" onclick="closeSpecialistModal()">Cancelar</button>
        <button class="btn btn-primary" id="btn-save-specialist" onclick="saveSpecialist()" style="flex:1">Salvar</button>
      </div>
    </div>
  </div>
</div>

<!-- Firebase SDKs -->
<script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-firestore-compat.js"></script>

<script src="js/firebase-config.js"></script>
<script src="js/cloudinary.js"></script>
<script src="js/auth.js"></script>
<script src="js/admin.js"></script>

<script>
// Data de hoje no dashboard
const hoje = new Date().toLocaleDateString('pt-BR', { weekday:'long', day:'numeric', month:'long', year:'numeric' });
const el = document.getElementById('today-label');
if (el) el.textContent = hoje.charAt(0).toUpperCase() + hoje.slice(1);

// Preview foto especialista
document.getElementById('spec-foto-input')?.addEventListener('change', function() {
  if (this.files[0]) {
    const reader = new FileReader();
    reader.onload = e => {
      document.getElementById('spec-foto-preview').src = e.target.result;
    };
    reader.readAsDataURL(this.files[0]);
  }
});

// PWA
if ('serviceWorker' in navigator) navigator.serviceWorker.register('sw.js');
</script>
</body>
</html>